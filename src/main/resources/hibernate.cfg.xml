<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration SYSTEM
"http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
  <session-factory>
    <!-- Use 'create' for first run, then change to 'update' -->
    <property name="hbm2ddl.auto">create</property>
    <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>
    <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
    <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/fsadexam?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true</property>
    <property name="hibernate.connection.username">root</property>
    <property name="hibernate.connection.password">kL2404401@</property>
    
    <!-- Connection pool settings -->
    <property name="hibernate.connection.pool_size">1</property>
    
    <!-- Show SQL in console -->
    <property name="hibernate.show_sql">true</property>
    <property name="hibernate.format_sql">true</property>
    
    <!-- Use the annotated Movie class -->
    <mapping class="com.klef.fsad.exam.Movie"/>
  </session-factory>
</hibernate-configuration>